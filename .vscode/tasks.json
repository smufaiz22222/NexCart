{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Full Stack (FE + BE + AI)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "servers"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Start Backend Server",
      "type": "shell",
      "command": "npm run dev:server",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "servers"
      }
    },
    {
      "label": "Start Frontend Server",
      "type": "shell",
      "command": "npm run dev:client",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "servers"
      }
    },
    {
      "label": "Start AI Service",
      "type": "shell",
      "command": "npm run dev:ai",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "servers"
      }
    },
    {
      "label": "Docker: Launch Full Stack",
      "type": "shell",
      "command": "docker-compose up --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint: All Projects",
      "type": "shell",
      "command": "npm run lint",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Format: All Projects",
      "type": "shell",
      "command": "npm run format",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
