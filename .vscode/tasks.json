{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "servers"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Start Frontend Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "servers"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Start AI Service",
      "type": "shell",
      "command": ".venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/ai-service"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "servers"
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Start All Services (FE + BE)",
      "dependsOn": [
        "Start Backend Server",
        "Start Frontend Server"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
