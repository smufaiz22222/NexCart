generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WHOLESALER
  SUPER_ADMIN
}

enum InventoryChangeReason {
  SALE
  REFUND
  OCR_UPDATE
  MANUAL_ADJUSTMENT
  CANCELLATION
  CUSTOMER_RETURN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_COMPLETED
}

enum PaymentMethod {
  COD
  PREPAID
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUND_PENDING
  REFUNDED
}

enum OrderIssueType {
  RETURN
  REFUND
  DISPUTE
}

enum OrderIssueStatus {
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

enum OrderIssueResolution {
  NONE
  REFUND
  REPLACEMENT
  STORE_CREDIT
  RETURNLESS_REFUND
}

enum InteractionAction {
  view
  wishlist
  cart
  purchase
  review
}

enum SimilarityMethod {
  CONTENT
  COLLABORATIVE
}

enum RecommendationEventType {
  impression
  click
  cart
  purchase
}

model User {
  id                      String                      @id @default(uuid())
  name                    String                      @default("User")
  email                   String                      @unique
  password                String
  role                    Role                        @default(CUSTOMER)
  reviews                 Review[]
  interactions            RecommendationInteraction[]
  recommendationLogs      RecommendationLog[]
  recommendationEvents    RecommendationEvent[]
  prepaidCheckoutSessions PrepaidCheckoutSession[]

  wholesalerProfile Wholesaler?

  ordersPlaced  Order[]       @relation("BuyerOrders")
  orderIssues   OrderIssue[]  @relation("OrderIssueRequester")
  ledgerEntries LedgerEntry[] @relation("UserLedger")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wholesaler {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id])
  businessName String

  products      Product[]
  orders        Order[]        @relation("SellerOrders")
  invoices      Invoice[]
  ledgerEntries LedgerEntry[]  @relation("WholesalerLedger")
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])

  name        String
  description String?
  price       Float
  costPrice   Float   @default(0)
  sku         String?
  imageUrl    String?

  category String   @default("General")
  sizes    String[]
  reviews  Review[]

  currentStock Int @default(0)
  minStock     Int @default(10)

  inventoryLogs        InventoryLog[]
  orderItems           OrderItem[]
  interactions         RecommendationInteraction[]
  feature              ProductFeature?
  similaritiesFrom     ProductSimilarity[]         @relation("ProductSimilaritySource")
  similaritiesTo       ProductSimilarity[]         @relation("ProductSimilarityTarget")
  recommendationEvents RecommendationEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryLog {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])

  changeAmount Int
  reason       InventoryChangeReason

  createdAt DateTime @default(now())
}

model Order {
  id String @id @default(uuid())

  sellerId String
  seller   Wholesaler @relation("SellerOrders", fields: [sellerId], references: [id])

  buyerId String
  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])

  status           OrderStatus   @default(PENDING)
  paymentMethod    PaymentMethod @default(COD)
  paymentStatus    PaymentStatus @default(PENDING)
  paymentProvider  String?
  paymentReference String?
  totalAmount      Decimal       @db.Decimal(10, 2)
  shippingAddress  String?

  items   OrderItem[]
  invoice Invoice?
  issues  OrderIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrepaidCheckoutSession {
  id               String        @id @default(uuid())
  buyerId          String
  buyer            User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  razorpayOrderId  String        @unique
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("INR")
  payload          Json
  paymentStatus    PaymentStatus @default(PENDING)
  paymentReference String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([buyerId])
  @@index([paymentStatus])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Decimal      @db.Decimal(10, 2)
  issues   OrderIssue[]
}

model OrderIssue {
  id                  String               @id @default(uuid())
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId         String?
  orderItem           OrderItem?           @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  requesterId         String
  requester           User                 @relation("OrderIssueRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  type                OrderIssueType
  status              OrderIssueStatus     @default(OPEN)
  preferredResolution OrderIssueResolution @default(NONE)
  finalResolution     OrderIssueResolution @default(NONE)
  reason              String
  description         String?
  requestedQuantity   Int                  @default(1)
  refundAmount        Decimal?             @db.Decimal(10, 2)
  sellerResponse      String?
  inventoryAdjusted   Boolean              @default(false)
  resolvedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([orderId])
  @@index([orderItemId])
  @@index([requesterId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Invoice {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  orderId      String     @unique
  order        Order      @relation(fields: [orderId], references: [id])

  amount       Decimal @db.Decimal(10, 2)
  ocrReference String?

  createdAt DateTime @default(now())
}

model LedgerEntry {
  id String @id @default(uuid())

  wholesalerId String
  wholesaler   Wholesaler @relation("WholesalerLedger", fields: [wholesalerId], references: [id])

  userId String?
  user   User?   @relation("UserLedger", fields: [userId], references: [id])

  amount      Decimal @db.Decimal(10, 2)
  description String
  referenceId String?

  createdAt DateTime @default(now())
}

model Review {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?

  createdAt DateTime @default(now())
}

model RecommendationInteraction {
  id               String             @id @default(uuid())
  userId           String?
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String?
  productId        String
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  action           InteractionAction
  quantity         Int                @default(1)
  source           String             @default("unknown")
  recommendationId String?
  recommendation   RecommendationLog? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  metadata         Json               @default("{}")
  createdAt        DateTime           @default(now())

  @@index([productId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([recommendationId])
  @@index([productId, action, createdAt])
}

model ProductFeature {
  productId   String   @id
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  textCorpus  String
  tfidfVector Json
  embedding   Json?
  version     Int      @default(1)
  updatedAt   DateTime @updatedAt
}

model ProductSimilarity {
  id               String           @id @default(uuid())
  productId        String
  product          Product          @relation("ProductSimilaritySource", fields: [productId], references: [id], onDelete: Cascade)
  similarProductId String
  similarProduct   Product          @relation("ProductSimilarityTarget", fields: [similarProductId], references: [id], onDelete: Cascade)
  method           SimilarityMethod
  score            Float
  rank             Int
  computedAt       DateTime         @default(now())

  @@unique([productId, similarProductId, method])
  @@index([productId, method, rank])
  @@index([similarProductId])
}

model RecommendationLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId    String?
  surface      String
  algorithm    String
  productIds   Json
  isEvaluation Boolean  @default(false)
  createdAt    DateTime @default(now())

  interactions RecommendationInteraction[]
  events       RecommendationEvent[]

  @@index([userId])
  @@index([sessionId])
  @@index([surface])
  @@index([algorithm])
  @@index([isEvaluation])
  @@index([createdAt])
}

model RecommendationEvent {
  id                  String                  @id @default(uuid())
  recommendationLogId String
  recommendationLog   RecommendationLog       @relation(fields: [recommendationLogId], references: [id], onDelete: Cascade)
  productId           String
  product             Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId           String?
  eventType           RecommendationEventType
  createdAt           DateTime                @default(now())

  @@index([recommendationLogId])
  @@index([recommendationLogId, eventType])
  @@index([productId, eventType, createdAt])
  @@index([userId])
  @@index([sessionId])
}

model RecommendationEvaluationReport {
  id         String   @id @default(uuid())
  reportType String   @default("offline")
  k          Int      @default(5)
  metrics    Json
  notes      String?
  createdAt  DateTime @default(now())

  @@index([reportType])
  @@index([createdAt])
}
