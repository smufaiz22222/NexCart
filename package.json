{
  "name": "nexcart",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm.cmd run dev:server\" \"pnpm.cmd run dev:client\" \"pnpm.cmd run dev:ai\"",
    "dev:server": "nodemon src/index.js",
    "dev:client": "pnpm.cmd --filter frontend dev",
    "dev:ai": "cd ai-service && .\\.venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
    "client:install": "pnpm.cmd install --filter frontend",
    "client:build": "pnpm.cmd --filter frontend build",
    "build": "pnpm.cmd run client:build",
    "lint": "concurrently \"eslint . --cache\" \"pnpm.cmd run lint:ai\"",
    "lint:fix": "concurrently \"eslint . --fix --cache\" \"pnpm.cmd run format:ai\"",
    "lint:ai": "cd ai-service && .\\.venv\\Scripts\\ruff check .",
    "format": "concurrently \"prettier --write .\" \"pnpm.cmd run format:ai\"",
    "format:check": "concurrently \"prettier --check .\" \"pnpm.cmd run lint:ai\"",
    "format:ai": "cd ai-service && .\\.venv\\Scripts\\ruff format .",
    "recommendations:build-content": "node src/jobs/buildContentRecommendations.js",
    "recommendations:build-cf": "node src/jobs/buildCollaborativeRecommendations.js",
    "recommendations:build-popularity": "node src/jobs/buildPopularityRecommendations.js",
    "recommendations:evaluate": "node src/jobs/evaluateRecommendations.js",
    "recommendations:benchmark": "node src/jobs/benchmarkRecommendations.js",
    "recommendations:seed-demo": "node prisma/seedRecommendationDemo.js",
    "recommendations:prepare-demo": "node src/jobs/prepareRecommendationDemo.js",
    "recommendations:test-access": "node src/jobs/testRecommendationAccess.js",
    "db:reset": "prisma migrate reset --force",
    "test": "node --test src/**/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.3.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "pg": "^8.13.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "7.8.0",
    "razorpay": "^2.9.6"
  }
}
