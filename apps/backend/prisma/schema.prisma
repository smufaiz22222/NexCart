generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WHOLESALER
  SUPER_ADMIN
}

enum InventoryChangeReason {
  SALE
  REFUND
  OCR_UPDATE
  MANUAL_ADJUSTMENT
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InteractionAction {
  view
  wishlist
  cart
  purchase
  review
}

enum SimilarityMethod {
  CONTENT
  COLLABORATIVE
}

enum RecommendationEventType {
  impression
  click
  cart
  purchase
}

model User {
  id        String   @id @default(uuid())
  name      String   @default("User")
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  reviews   Review[]
  interactions RecommendationInteraction[]
  recommendationLogs RecommendationLog[]
  recommendationEvents RecommendationEvent[]

  wholesalerProfile Wholesaler? 

  ordersPlaced  Order[]       @relation("BuyerOrders")
  ledgerEntries LedgerEntry[] @relation("UserLedger")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wholesaler {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  businessName String
  
  products      Product[]
  orders        Order[]        @relation("SellerOrders")
  invoices      Invoice[]
  ledgerEntries LedgerEntry[]  @relation("WholesalerLedger")
  inventoryLogs InventoryLog[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  
  name         String
  description  String?
  price        Float    
  costPrice    Float      @default(0)
  sku          String?
  imageUrl     String? 

  category      String   @default("General") 
  sizes         String[]
  reviews       Review[]
  
  currentStock Int        @default(0) 
  minStock     Int        @default(10)
  
  inventoryLogs InventoryLog[]
  orderItems    OrderItem[]
  interactions  RecommendationInteraction[]
  feature       ProductFeature?
  similaritiesFrom ProductSimilarity[] @relation("ProductSimilaritySource")
  similaritiesTo   ProductSimilarity[] @relation("ProductSimilarityTarget")
  recommendationEvents RecommendationEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryLog {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  
  changeAmount Int        
  reason       InventoryChangeReason
  
  createdAt    DateTime   @default(now())
}

model Order {
  id           String      @id @default(uuid())
  
  sellerId     String
  seller       Wholesaler  @relation("SellerOrders", fields: [sellerId], references: [id])
  
  buyerId      String
  buyer        User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(10, 2)
  shippingAddress String?

  items        OrderItem[]
  invoice      Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Decimal @db.Decimal(10, 2) 
}

model Invoice {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  orderId      String     @unique
  order        Order      @relation(fields: [orderId], references: [id])
  
  amount       Decimal    @db.Decimal(10, 2)
  ocrReference String?    
  
  createdAt    DateTime   @default(now())
}

model LedgerEntry {
  id           String     @id @default(uuid())
  
  wholesalerId String
  wholesaler   Wholesaler @relation("WholesalerLedger", fields: [wholesalerId], references: [id])
  
  userId       String?    
  user         User?      @relation("UserLedger", fields: [userId], references: [id])
  
  amount       Decimal    @db.Decimal(10, 2) 
  description  String
  referenceId  String?    
  
  createdAt    DateTime   @default(now())
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  
  createdAt DateTime @default(now())
}

model RecommendationInteraction {
  id               String            @id @default(uuid())
  userId           String?
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String?
  productId        String
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  action           InteractionAction
  quantity         Int               @default(1)
  source           String            @default("unknown")
  recommendationId String?
  recommendation   RecommendationLog? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())

  @@index([productId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([productId, action, createdAt])
}

model ProductFeature {
  productId   String   @id
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  textCorpus  String
  tfidfVector Json
  embedding   Json?
  version     Int      @default(1)
  updatedAt   DateTime @updatedAt
}

model ProductSimilarity {
  id               String           @id @default(uuid())
  productId        String
  product          Product          @relation("ProductSimilaritySource", fields: [productId], references: [id], onDelete: Cascade)
  similarProductId String
  similarProduct   Product          @relation("ProductSimilarityTarget", fields: [similarProductId], references: [id], onDelete: Cascade)
  method           SimilarityMethod
  score            Float
  rank             Int
  computedAt       DateTime         @default(now())

  @@unique([productId, similarProductId, method])
  @@index([productId, method, rank])
  @@index([similarProductId])
}

model RecommendationLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId    String?
  surface      String
  algorithm    String
  productIds   Json
  createdAt    DateTime @default(now())

  interactions RecommendationInteraction[]
  events       RecommendationEvent[]

  @@index([userId])
  @@index([surface])
  @@index([algorithm])
  @@index([createdAt])
}

model RecommendationEvent {
  id                  String                  @id @default(uuid())
  recommendationLogId String
  recommendationLog   RecommendationLog       @relation(fields: [recommendationLogId], references: [id], onDelete: Cascade)
  productId           String
  product             Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId           String?
  eventType           RecommendationEventType
  createdAt           DateTime                @default(now())

  @@index([recommendationLogId])
  @@index([productId, eventType, createdAt])
  @@index([userId])
}
