generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  WHOLESALER
  SUPER_ADMIN
}

enum OnboardingStatus {
  APPLIED
  UNDER_REVIEW
  APPROVED
  ACTIVE
  PAST_DUE
  SUSPENDED
  REJECTED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  EXPIRED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
}

enum SubscriptionPurchaseMethod {
  TRIAL
  RAZORPAY
  ADMIN_MANUAL
  COUPON
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum InventoryChangeReason {
  SALE
  REFUND
  OCR_UPDATE
  MANUAL_ADJUSTMENT
  CANCELLATION
  CUSTOMER_RETURN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_COMPLETED
}

enum PaymentMethod {
  COD
  PREPAID
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUND_PENDING
  REFUNDED
}

enum PaymentCaptureStatus {
  NOT_APPLICABLE
  CAPTURED
  UNCERTAIN
}

enum LedgerEntrySource {
  MANUAL
  ORDER_CHARGE
  ORDER_AUTO_PAYMENT
  ORDER_PREPAID_PAYMENT
  ORDER_CANCELLATION
  CUSTOMER_RETURN
  RETURN_REFUND
  RETURN_ADJUSTMENT
}

enum ReturnStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  RETURN_COMPLETED
}

enum ReturnRefundStatus {
  NONE
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum ReturnReason {
  WRONG_ITEM
  DAMAGED
  DEFECTIVE
  CHANGED_MIND
  MISSING_PARTS
  OTHER
}

enum OrderAdjustmentType {
  RETURN
}

enum OrderIssueType {
  RETURN
  REFUND
  DISPUTE
}

enum OrderIssueStatus {
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

enum OrderIssueResolution {
  NONE
  REFUND
  REPLACEMENT
  STORE_CREDIT
  RETURNLESS_REFUND
}

enum InteractionAction {
  view
  wishlist
  cart
  purchase
  review
}

enum SimilarityMethod {
  CONTENT
  COLLABORATIVE
}

enum RecommendationEventType {
  impression
  click
  cart
  purchase
}

enum OrderItemStatus {
  ACTIVE
  CANCELLED
}

enum RefundStatus {
  NOT_APPLICABLE
  PENDING
  PROCESSING
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum DisputeReason {
  DAMAGED_ITEM
  WRONG_ITEM
  MISSING_PARTS
  DEFECTIVE_PRODUCT
  QUALITY_ISSUE
  NOT_AS_DESCRIBED
  OTHER
}

enum DisputeResolutionType {
  APPROVE
  REJECT
  PARTIAL_REFUND
}

enum DisputeResolvedByRole {
  SELLER
  ADMIN
}

enum DisputeEventType {
  OPENED
  UNDER_REVIEW
  NOTE_ADDED
  RESOLUTION_CREATED
  APPROVED
  REJECTED
  PARTIAL_REFUND
}

model User {
  id                      String                      @id @default(uuid())
  name                    String                      @default("User")
  email                   String                      @unique
  password                String
  role                    Role                        @default(CUSTOMER)
  cart                    Cart?
  shippingAddresses       ShippingAddress[]
  reviews                 Review[]
  interactions            RecommendationInteraction[]
  recommendationLogs      RecommendationLog[]
  recommendationEvents    RecommendationEvent[]
  prepaidCheckoutSessions PrepaidCheckoutSession[]

  wholesalerProfile Wholesaler?
  businessProfile   BusinessProfile?

  ordersPlaced         Order[]               @relation("BuyerOrders")
  orderIssues          OrderIssue[]          @relation("OrderIssueRequester")
  ledgerEntries        LedgerEntry[]         @relation("UserLedger")
  disputesOpened       Dispute[]             @relation("BuyerDisputes")
  disputeResolutions   DisputeResolution[]   @relation("DisputeResolvedByUser")
  disputeInternalNotes DisputeInternalNote[] @relation("DisputeInternalNoteAuthor")
  disputeEvents        DisputeEvent[]        @relation("DisputeEventPerformer")
  rfqs                 Rfq[]
  wholesalerCreditLimits WholesalerCreditLimit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wholesaler {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id])
  businessName String
  businessPhone String?
  taxId         String?
  businessAddress String?
  onboardingStatus OnboardingStatus @default(ACTIVE)
  reviewSubmittedAt DateTime?
  approvedAt DateTime?
  rejectedAt DateTime?
  suspendedAt DateTime?
  activatedAt DateTime?
  rejectionReason String?
  trialStartedAt DateTime?
  trialEndsAt DateTime?
  trialUsedAt DateTime?

  products      Product[]
  orders        Order[]        @relation("SellerOrders")
  invoices      Invoice[]
  ledgerEntries LedgerEntry[]  @relation("WholesalerLedger")
  inventoryLogs InventoryLog[]
  disputes      Dispute[]      @relation("SellerDisputes")
  subscriptions WholesalerSubscription[]
  subscriptionPayments SubscriptionPayment[]
  rfqs          Rfq[]
  creditLimits  WholesalerCreditLimit[]
  usedCoupons   Coupon[]       @relation("WholesalerCoupon")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  features    Json
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  subscriptions WholesalerSubscription[]
  payments    SubscriptionPayment[]
  coupons     Coupon[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WholesalerSubscription {
  id                String                      @id @default(uuid())
  wholesalerId      String
  wholesaler        Wholesaler                  @relation(fields: [wholesalerId], references: [id])
  planId            String
  plan              SubscriptionPlan            @relation(fields: [planId], references: [id])
  status            SubscriptionStatus          @default(PENDING)
  billingCycle      BillingCycle                @default(MONTHLY)
  durationMonths    Int                         @default(1)
  purchaseMethod    SubscriptionPurchaseMethod
  activatedByAdmin  Boolean                     @default(false)
  activationNotes   String?
  externalReference String?
  startedAt         DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  autoRenews        Boolean                     @default(false)
  payments          SubscriptionPayment[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([wholesalerId, status])
  @@index([planId])
}

model SubscriptionPayment {
  id                String                      @id @default(uuid())
  wholesalerId      String
  wholesaler        Wholesaler                  @relation(fields: [wholesalerId], references: [id])
  subscriptionId    String?
  subscription      WholesalerSubscription?     @relation(fields: [subscriptionId], references: [id])
  planId            String?
  plan              SubscriptionPlan?           @relation(fields: [planId], references: [id])
  purchaseMethod    SubscriptionPurchaseMethod
  status            SubscriptionPaymentStatus   @default(PENDING)
  durationMonths    Int                         @default(1)
  baseAmount        Decimal                     @db.Decimal(10, 2)
  discountPercent   Int                         @default(0)
  finalAmount       Decimal                     @db.Decimal(10, 2)
  currency          String                      @default("INR")
  razorpayOrderId   String?                     @unique
  razorpayPaymentId String?
  razorpaySignature String?
  externalReference String?
  activationNotes   String?
  failureReason     String?
  paidAt            DateTime?
  validUntil        DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([wholesalerId, status])
  @@index([subscriptionId])
}

model Coupon {
  id           String           @id @default(uuid())
  code         String           @unique
  planId       String
  plan         SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  durationDays Int
  expiryDate   DateTime
  isUsed       Boolean          @default(false)
  usedById     String?
  usedBy       Wholesaler?      @relation(fields: [usedById], references: [id], name: "WholesalerCoupon")
  usedAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([code])
}

model Product {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])

  name        String
  description String?
  price       Float
  costPrice   Float   @default(0)
  sku         String?
  imageUrl    String?

  category String   @default("General")
  sizes    String[]
  reviews  Review[]

  currentStock Int @default(0)
  minStock     Int @default(10)

  isB2BEnabled Boolean @default(true)
  minOrderQty  Int     @default(1)

  cartItems            CartItem[]
  inventoryLogs        InventoryLog[]
  orderItems           OrderItem[]
  interactions         RecommendationInteraction[]
  feature              ProductFeature?
  similaritiesFrom     ProductSimilarity[]         @relation("ProductSimilaritySource")
  similaritiesTo       ProductSimilarity[]         @relation("ProductSimilarityTarget")
  recommendationEvents RecommendationEvent[]
  priceTiers           ProductPriceTier[]
  rfqs                 Rfq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wholesalerId])
  @@index([category])
  @@index([currentStock])
}

model InventoryLog {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])

  changeAmount Int
  reason       InventoryChangeReason

  createdAt DateTime @default(now())

  @@index([wholesalerId])
  @@index([productId])
}

model Order {
  id String @id @default(uuid())

  sellerId String
  seller   Wholesaler @relation("SellerOrders", fields: [sellerId], references: [id])

  buyerId String
  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])

  status               OrderStatus          @default(PENDING)
  paymentMethod        PaymentMethod        @default(COD)
  paymentStatus        PaymentStatus        @default(PENDING)
  paymentCaptureStatus PaymentCaptureStatus @default(NOT_APPLICABLE)
  paymentProvider      String?
  paymentReference     String?
  razorpayPaymentId    String?
  razorpayOrderId      String?
  totalAmount          Decimal              @db.Decimal(10, 2)
  shippingAddress      String?
  shippingStreet       String?
  shippingCity         String?
  shippingState        String?
  shippingPostalCode   String?

  items         OrderItem[]
  invoice       Invoice?
  issues        OrderIssue[]
  disputes      Dispute[]
  ledgerEntries LedgerEntry[]
  adjustments   OrderAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([shippingCity])
  @@index([shippingState])
}

model PrepaidCheckoutSession {
  id               String        @id @default(uuid())
  buyerId          String
  buyer            User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  razorpayOrderId  String        @unique
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("INR")
  payload          Json
  paymentStatus    PaymentStatus @default(PENDING)
  paymentReference String?
  processedAt      DateTime?
  createdOrderIds  String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([buyerId])
  @@index([paymentStatus])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity             Int
  price                Decimal            @db.Decimal(10, 2)
  unitPriceAtPurchase  Decimal            @db.Decimal(10, 2)
  subtotalAtPurchase   Decimal            @db.Decimal(10, 2)
  selectedSize         String?
  recommendationId     String?
  status               OrderItemStatus    @default(ACTIVE)
  cancelledAt          DateTime?
  cancelledByRole      Role?
  cancellationReason   String?
  refundStatus         RefundStatus       @default(NOT_APPLICABLE)
  refundReference      String?
  refundFailureReason  String?
  refundRequestedAt    DateTime?
  refundCompletedAt    DateTime?
  refundedAmount       Decimal?           @db.Decimal(10, 2)
  returnStatus         ReturnStatus       @default(NONE)
  returnRefundStatus   ReturnRefundStatus @default(NONE)
  returnReason         ReturnReason?
  customerReturnNotes  String?
  rejectionReason      String?
  decisionBy           String?
  returnedQuantity     Int                @default(0)
  refundAmountSnapshot Decimal?           @db.Decimal(10, 2)
  inventoryRestored    Boolean            @default(false)
  refundAttemptCount   Int                @default(0)
  gatewayRefundId      String?
  gatewayResponse      Json?
  returnRequestedAt    DateTime?
  returnApprovedAt     DateTime?
  returnRejectedAt     DateTime?
  returnReceivedAt     DateTime?
  returnCompletedAt    DateTime?
  returnEligibleUntil  DateTime?
  issues               OrderIssue[]
  adjustments          OrderAdjustment[]
  disputes             Dispute[]

  @@index([orderId, status])
  @@index([refundStatus])
  @@index([returnStatus])
  @@index([returnRefundStatus])
  @@index([productId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model CartItem {
  id                   String   @id @default(uuid())
  cartId               String
  cart                 Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId            String
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  selectedSize         String?
  quantity             Int
  recommendationId     String?
  recommendationSource String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([cartId, productId, selectedSize])
  @@index([cartId])
  @@index([productId])
}

model ShippingAddress {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  state        String
  postalCode   String
  country      String   @default("India")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

model OrderIssue {
  id                  String               @id @default(uuid())
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId         String?
  orderItem           OrderItem?           @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  requesterId         String
  requester           User                 @relation("OrderIssueRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  type                OrderIssueType
  status              OrderIssueStatus     @default(OPEN)
  preferredResolution OrderIssueResolution @default(NONE)
  finalResolution     OrderIssueResolution @default(NONE)
  reason              String
  description         String?
  requestedQuantity   Int                  @default(1)
  refundAmount        Decimal?             @db.Decimal(10, 2)
  sellerResponse      String?
  inventoryAdjusted   Boolean              @default(false)
  resolvedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([orderId])
  @@index([orderItemId])
  @@index([requesterId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Dispute {
  id                 String                @id @default(uuid())
  orderId            String
  order              Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId        String
  orderItem          OrderItem             @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  buyerId            String
  buyer              User                  @relation("BuyerDisputes", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId           String
  seller             Wholesaler            @relation("SellerDisputes", fields: [sellerId], references: [id], onDelete: Cascade)
  status             DisputeStatus         @default(OPEN)
  reason             DisputeReason
  description        String
  openedAt           DateTime              @default(now())
  respondedAt        DateTime?
  dueAt              DateTime?
  createdByIp        String?
  createdByUserAgent String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  resolution         DisputeResolution?
  evidence           DisputeEvidence[]
  internalNotes      DisputeInternalNote[]
  events             DisputeEvent[]

  @@index([orderId])
  @@index([orderItemId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([sellerId, status])
  @@index([sellerId, reason, createdAt])
}

model DisputeResolution {
  id               String                @id @default(uuid())
  disputeId        String                @unique
  dispute          Dispute               @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  resolvedByUserId String
  resolvedByUser   User                  @relation("DisputeResolvedByUser", fields: [resolvedByUserId], references: [id], onDelete: Restrict)
  resolvedByRole   DisputeResolvedByRole
  resolutionType   DisputeResolutionType
  resolutionNotes  String?
  resolutionAmount Decimal?              @db.Decimal(10, 2)
  refundId         String?
  ledgerEntryId    String?
  createdAt        DateTime              @default(now())
}

model DisputeEvidence {
  id        String   @id @default(uuid())
  disputeId String
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@unique([disputeId, url])
  @@index([disputeId])
}

model DisputeInternalNote {
  id        String   @id @default(uuid())
  disputeId String
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("DisputeInternalNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  note      String
  createdAt DateTime @default(now())

  @@index([disputeId])
}

model DisputeEvent {
  id                String           @id @default(uuid())
  disputeId         String
  dispute           Dispute          @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  type              DisputeEventType
  performedByUserId String?
  performedByUser   User?            @relation("DisputeEventPerformer", fields: [performedByUserId], references: [id], onDelete: SetNull)
  notes             String?
  createdAt         DateTime         @default(now())

  @@index([disputeId, createdAt])
}

model Invoice {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id])
  orderId      String     @unique
  order        Order      @relation(fields: [orderId], references: [id])

  amount       Decimal @db.Decimal(10, 2)
  ocrReference String?

  createdAt DateTime @default(now())
}

model LedgerEntry {
  id String @id @default(uuid())

  wholesalerId String
  wholesaler   Wholesaler @relation("WholesalerLedger", fields: [wholesalerId], references: [id])

  userId  String?
  user    User?   @relation("UserLedger", fields: [userId], references: [id])
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  amount         Decimal           @db.Decimal(10, 2)
  description    String
  referenceId    String?
  source         LedgerEntrySource @default(MANUAL)
  idempotencyKey String?           @unique

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([wholesalerId])
  @@index([userId])
}

model OrderAdjustment {
  id           String              @id @default(uuid())
  orderId      String
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId  String?
  orderItem    OrderItem?          @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  type         OrderAdjustmentType
  quantity     Int                 @default(0)
  amount       Decimal             @db.Decimal(10, 2)
  description  String
  referenceKey String              @unique
  createdAt    DateTime            @default(now())

  @@index([orderId])
  @@index([orderItemId])
  @@index([type])
}

model Review {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?

  createdAt DateTime @default(now())
}

model RecommendationInteraction {
  id               String             @id @default(uuid())
  userId           String?
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String?
  productId        String
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  action           InteractionAction
  quantity         Int                @default(1)
  source           String             @default("unknown")
  recommendationId String?
  recommendation   RecommendationLog? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  metadata         Json               @default("{}")
  createdAt        DateTime           @default(now())

  @@index([productId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([recommendationId])
  @@index([productId, action, createdAt])
}

model ProductFeature {
  productId   String   @id
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  textCorpus  String
  tfidfVector Json
  embedding   Json?
  version     Int      @default(1)
  updatedAt   DateTime @updatedAt
}

model ProductSimilarity {
  id               String           @id @default(uuid())
  productId        String
  product          Product          @relation("ProductSimilaritySource", fields: [productId], references: [id], onDelete: Cascade)
  similarProductId String
  similarProduct   Product          @relation("ProductSimilarityTarget", fields: [similarProductId], references: [id], onDelete: Cascade)
  method           SimilarityMethod
  score            Float
  rank             Int
  computedAt       DateTime         @default(now())

  @@unique([productId, similarProductId, method])
  @@index([productId, method, rank])
  @@index([similarProductId])
}

model RecommendationLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId    String?
  surface      String
  algorithm    String
  productIds   Json
  isEvaluation Boolean  @default(false)
  createdAt    DateTime @default(now())

  interactions RecommendationInteraction[]
  events       RecommendationEvent[]

  @@index([userId])
  @@index([sessionId])
  @@index([surface])
  @@index([algorithm])
  @@index([isEvaluation])
  @@index([createdAt])
}

model RecommendationEvent {
  id                  String                  @id @default(uuid())
  recommendationLogId String
  recommendationLog   RecommendationLog       @relation(fields: [recommendationLogId], references: [id], onDelete: Cascade)
  productId           String
  product             Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId           String?
  eventType           RecommendationEventType
  createdAt           DateTime                @default(now())

  @@index([recommendationLogId])
  @@index([recommendationLogId, eventType])
  @@index([productId, eventType, createdAt])
  @@index([userId])
  @@index([sessionId])
}

model RecommendationEvaluationReport {
  id         String   @id @default(uuid())
  reportType String   @default("offline")
  k          Int      @default(5)
  metrics    Json
  notes      String?
  createdAt  DateTime @default(now())

  @@index([reportType])
  @@index([createdAt])
}

model BusinessProfile {
  id              String           @id @default(uuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  taxId           String
  businessAddress String
  verification    OnboardingStatus @default(APPLIED)
  status          OnboardingStatus @default(ACTIVE)
  rejectionReason String?
  rfqs            Rfq[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model WholesalerCreditLimit {
  id           String     @id @default(uuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id], onDelete: Cascade)
  buyerId      String
  buyer        User       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  creditLimit  Decimal    @default(50000.00) @db.Decimal(10, 2)
  balance      Decimal    @default(0.00) @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([wholesalerId, buyerId])
}

model ProductPriceTier {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity Int
  unitPrice   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, minQuantity])
}

enum RfqStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTER_OFFERED
  ORDER_PLACED
}

model Rfq {
  id                String           @id @default(uuid())
  buyerId           String
  buyer             User             @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId          String
  seller            Wholesaler       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId         String
  product           Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity          Int
  targetPrice       Float
  counterPrice      Float?
  status            RfqStatus        @default(PENDING)
  notes             String?
  sellerNotes       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  BusinessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id])
  businessProfileId String?
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

